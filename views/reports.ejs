<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Reports - Smart Billing</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
    <script src="https://unpkg.com/@phosphor-icons/web"></script>
    <link rel="stylesheet" href="/css/style.css">
    <style>
        .reports-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(200px, 1fr));
            gap: 1.5rem;
            margin-bottom: 2rem;
        }
        .report-card {
            padding: 1.5rem;
            display: flex;
            flex-direction: column;
            gap: 1rem;
            border-radius: 12px;
            transition: var(--transition);
        }
        .report-card:hover {
            transform: translateY(-3px);
            border-color: rgba(99, 102, 241, 0.4);
            box-shadow: 0 0 20px rgba(99, 102, 241, 0.1);
        }
        .report-header {
            display: flex;
            align-items: center;
            gap: 0.75rem;
            color: var(--text-secondary);
            font-size: 1.1rem;
            font-weight: 500;
        }
        .report-header i {
            font-size: 1.5rem;
            color: var(--primary);
            background: rgba(99, 102, 241, 0.15);
            padding: 0.5rem;
            border-radius: 8px;
        }
        .report-value {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-primary);
        }
        .all-content-container {
            display: flex;
            flex-direction: column;
            height: calc(100vh - 90px);
            padding-right: 1rem;
            overflow-y: auto;
        }
        .all-content-container::-webkit-scrollbar {
            width: 4px;
        }
        .all-content-container::-webkit-scrollbar-thumb {
            background: var(--border-color);
            border-radius: 4px;
        }
        .page-header {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 2rem;
        }
    </style>
</head>
<body class="dark-theme">
    <div class="app-layout">
        
        <aside class="sidebar glass-panel">
            <div class="sidebar-header">
                <i class="ph-fill ph-receipt highlight-icon"></i>
                <h1>Smart<span class="highlight">Bill</span></h1>
            </div>

            <div class="sidebar-section">
                <h3 class="section-title">Navigation</h3>
                <nav class="nav-menu">
                    <a href="/" class="nav-item"><i class="ph ph-squares-four"></i> Dashboard</a>
                    <a href="/customers" class="nav-item"><i class="ph ph-users"></i> Customers</a>
                    <a href="/reports" class="nav-item active"><i class="ph ph-chart-bar"></i> Reports</a>
                </nav>
            </div>

            <div class="sidebar-section receipts-section">
                <h3 class="section-title">Recent Receipts <span class="badge"><%= receipts.length %></span></h3>
                <div class="receipt-list-container">
                    <% if (receipts.length > 0) { %>
                        <ul class="receipt-list">
                            <% receipts.slice().reverse().forEach(receipt => { %>
                                <li>
                                    <a href="/receipt/<%= receipt.id %>" class="receipt-card">
                                        <div class="receipt-icon"><i class="ph ph-file-text"></i></div>
                                        <div class="receipt-info">
                                            <span class="receipt-id"><%= receipt.customerName %></span>
                                            <span class="receipt-date"><%= receipt.date.split(',')[0] %></span>
                                        </div>
                                        <% if (receipt.status === 'Unpaid') { %>
                                            <span class="receipt-total" style="color: #ef4444;" title="Unpaid">₹<%= formatCurrency(receipt.total) %> <i class="ph ph-warning-circle"></i></span>
                                        <% } else { %>
                                            <span class="receipt-total">₹<%= formatCurrency(receipt.total) %></span>
                                        <% } %>
                                    </a>
                                </li>
                            <% }) %>
                        </ul>
                    <% } else { %>
                        <div class="empty-receipts">
                            <i class="ph ph-files"></i>
                            <p>No recent activity</p>
                        </div>
                    <% } %>
                </div>
            </div>
        </aside>

        <!-- Main Content Area -->
        <main class="main-content">
            
            <header class="topbar">
                <div class="search-bar">
                    <i class="ph ph-magnifying-glass"></i>
                    <input type="text" placeholder="Search reports...">
                </div>
                <div class="user-profile">
                    <div class="notification-bell">
                        <i class="ph ph-bell"></i>
                        <span class="indicator"></span>
                    </div>
                    <div class="avatar">
                        <img src="https://api.dicebear.com/7.x/notionists/svg?seed=Admin" alt="User Avatar">
                    </div>
                </div>
            </header>

            <div class="all-content-container">
                <div class="page-header">
                    <h2>Financial Reports</h2>
                    <span class="badge" style="font-size: 1rem; padding: 0.5rem 1rem;">Transaction Summary</span>
                </div>

                <div class="reports-grid">
                    <div class="report-card glass-panel" onclick="filterTransactions('today')" style="cursor: pointer;" title="Show Today's Transactions">
                        <div class="report-header">
                            <i class="ph ph-calendar-blank"></i> Today's Revenue
                        </div>
                        <div class="report-value highlight">₹<%= formatCurrency(todayTotal) %></div>
                    </div>



                    <div class="report-card glass-panel" onclick="filterTransactions('month')" style="cursor: pointer;" title="Show This Month's Transactions">
                        <div class="report-header">
                            <i class="ph ph-calendar"></i> This Month
                        </div>
                        <div class="report-value highlight">₹<%= formatCurrency(monthTotal) %></div>
                    </div>

                    <div class="report-card glass-panel" onclick="filterTransactions('year')" style="cursor: pointer;" title="Show This Year's Transactions">
                        <div class="report-header">
                            <i class="ph ph-calendar-check"></i> This Year
                        </div>
                        <div class="report-value highlight">₹<%= formatCurrency(yearTotal) %></div>
                    </div>

                    <div class="report-card glass-panel" onclick="filterTransactions('unpaid')" style="cursor: pointer; border-color: rgba(239, 68, 68, 0.4);" title="Show Unpaid Transactions">
                        <div class="report-header" style="color: #ef4444;">
                            <i class="ph ph-warning-circle" style="color: #ef4444; background: rgba(239, 68, 68, 0.15);"></i> Unpaid Amount
                        </div>
                        <div class="report-value highlight" style="color: #ef4444;">₹<%= formatCurrency(unpaidTotal) %></div>
                    </div>
                </div>

                <div class="recent-transactions-section glass-panel" style="padding: 1.5rem; flex: 1; border-radius: 12px;">
                    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1.5rem;">
                        <h3 id="tableTitle" style="font-weight: 600; margin: 0;">All Transactions</h3>
                        <button onclick="filterTransactions('all')" class="btn glass-panel" style="background: rgba(255,255,255,0.05); color: var(--text-secondary); padding: 0.25rem 0.75rem; font-size: 0.85rem;">Clear Filter</button>
                    </div>
                    <% if (receipts.length > 0) { %>
                        <div style="overflow-x: auto;">
                            <table style="width: 100%; border-collapse: collapse; text-align: left;">
                                <thead>
                                    <tr style="border-bottom: 1px solid var(--border-color); color: var(--text-secondary);">
                                        <th style="padding: 1rem;">Receipt ID</th>
                                        <th style="padding: 1rem;">Date</th>
                                        <th style="padding: 1rem;">Customer</th>
                                        <th style="padding: 1rem; text-align: right;">Total Amount</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <% receipts.slice().reverse().forEach(receipt => { 
                                        let parsedDate = new Date(receipt.date);
                                        let timestamp = isNaN(parsedDate.getTime()) ? 0 : parsedDate.getTime();
                                        if (isNaN(parsedDate.getTime())) {
                                            let parts = receipt.date.split(',')[0].split('/');
                                            if (parts.length === 3) {
                                                parsedDate = new Date(`${parts[2]}-${parts[1]}-${parts[0]}`);
                                                timestamp = isNaN(parsedDate.getTime()) ? 0 : parsedDate.getTime();
                                            }
                                        }
                                    %>
                                        <tr class="transaction-row" data-year="<%= receipt.parsedYear %>" data-month="<%= receipt.parsedMonth %>" data-date="<%= receipt.parsedDate %>" data-timestamp="<%= timestamp %>" data-status="<%= receipt.status || 'Unpaid' %>" style="border-bottom: 1px dashed rgba(255,255,255,0.05); transition: background 0.2s;">
                                            <td style="padding: 1rem;"><a href="/receipt/<%= receipt.id %>" style="color: var(--primary); text-decoration: underline; font-weight: 500;">#<%= receipt.id %></a></td>
                                            <td style="padding: 1rem; color: var(--text-secondary);"><%= receipt.date %></td>
                                            <td style="padding: 1rem;"><%= receipt.customerName %></td>
                                            <td style="padding: 1rem; text-align: right; font-weight: 600;">₹<%= formatCurrency(receipt.total) %></td>
                                        </tr>
                                    <% }) %>
                                </tbody>
                            </table>
                        </div>
                    <% } else { %>
                        <p style="color: var(--text-secondary);">No transactions available yet.</p>
                    <% } %>
                </div>

            </div>
        </main>
    </div>

    <script>
        const currentYear = new Date().getFullYear();
        const currentMonth = new Date().getMonth();
        const currentDate = new Date().getDate();

        function filterTransactions(filterType) {
            const rows = document.querySelectorAll('.transaction-row');
            const title = document.getElementById('tableTitle');

            if (filterType === 'all') title.innerText = 'All Transactions';
            else if (filterType === 'year') title.innerText = 'This Year\'s Transactions';
            else if (filterType === 'month') title.innerText = 'This Month\'s Transactions';
            else if (filterType === 'today') title.innerText = 'Today\'s Transactions';
            else if (filterType === 'unpaid') title.innerText = 'Unpaid Transactions';

            rows.forEach(row => {
                const rowYear = parseInt(row.getAttribute('data-year'), 10);
                const rowMonth = parseInt(row.getAttribute('data-month'), 10);
                const rowDate = parseInt(row.getAttribute('data-date'), 10);
                const rowStatus = row.getAttribute('data-status');
                
                let show = false;
                
                if (filterType === 'all') {
                    show = true;
                } else if (filterType === 'year') {
                    if (rowYear === currentYear) show = true;
                } else if (filterType === 'month') {
                    if (rowYear === currentYear && rowMonth === currentMonth) show = true;
                } else if (filterType === 'today') {
                    if (rowYear === currentYear && rowMonth === currentMonth && rowDate === currentDate) show = true;
                } else if (filterType === 'unpaid') {
                    if (rowStatus === 'Unpaid') show = true;
                }
                
                if (show) {
                    row.style.display = '';
                } else {
                    row.style.display = 'none';
                }
            });
        }
    </script>
</body>
</html>
